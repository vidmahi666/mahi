{
  "info": {
    "name": "EduConnect API",
    "description": "Complete API collection for EduConnect - Digital Education & E-Learning Governance System.\n\n## Quick Start\n1. Run `POST /api/auth/login` with pre-seeded credentials\n2. Copy the `accessToken` from the response\n3. It is auto-saved to the `{{token}}` variable\n4. All other requests use it automatically",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",    "value": "http://localhost:8080", "type": "string" },
    { "key": "token",      "value": "",                      "type": "string" },
    { "key": "studentId",  "value": "1",                     "type": "string" },
    { "key": "courseId",   "value": "1",                     "type": "string" },
    { "key": "assessmentId","value":"1",                     "type": "string" },
    { "key": "enrollmentId","value":"1",                     "type": "string" },
    { "key": "contentId",  "value": "1",                     "type": "string" },
    { "key": "submissionId","value":"1",                     "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "01 - Authentication",
      "item": [
        {
          "name": "Register - Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Admin\",\n  \"email\": \"newadmin@test.com\",\n  \"password\": \"password123\",\n  \"role\": \"ADMIN\"\n}"
            }
          }
        },
        {
          "name": "Register - Student",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Student\",\n  \"email\": \"alice@student.com\",\n  \"password\": \"password123\",\n  \"role\": \"STUDENT\",\n  \"phone\": \"9876543210\"\n}"
            }
          }
        },
        {
          "name": "Register - Teacher",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dr. New Teacher\",\n  \"email\": \"newteacher@test.com\",\n  \"password\": \"password123\",\n  \"role\": \"TEACHER\"\n}"
            }
          }
        },
        {
          "name": "Login - Admin (auto-saves token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.accessToken) {",
                  "    pm.collectionVariables.set('token', res.data.accessToken);",
                  "    console.log('Token saved:', res.data.accessToken.substring(0,20) + '...');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@educonnect.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login - Teacher (auto-saves token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.accessToken) {",
                  "    pm.collectionVariables.set('token', res.data.accessToken);",
                  "    console.log('Teacher token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"sarah.johnson@educonnect.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login - Student (auto-saves token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.accessToken) {",
                  "    pm.collectionVariables.set('token', res.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@student.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login - Bad Credentials (expect 401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@educonnect.com\",\n  \"password\": \"wrongpassword\"\n}"
            }
          }
        },
        {
          "name": "Login - Validation Error (expect 400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"not-an-email\",\n  \"password\": \"\"\n}"
            }
          }
        }
      ]
    },
