        {
          "name": "Generate Student Report",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/reports/generate/STUDENT" }
        },
        {
          "name": "Generate Compliance Report",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/reports/generate/COMPLIANCE" }
        }
      ]
    },
    {
      "name": "13 - Student Documents",
      "item": [
        {
          "name": "Get Documents by Student",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/student-documents/student/{{studentId}}" }
        },
        {
          "name": "Upload Student Document",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/student-documents/student/{{studentId}}?docType=ID_PROOF&fileUri=https://s3.amazonaws.com/docs/id-proof.jpg",
              "query": [
                { "key": "docType",  "value": "ID_PROOF" },
                { "key": "fileUri",  "value": "https://s3.amazonaws.com/docs/id-proof.jpg" }
              ]
            }
          }
        },
        {
          "name": "Verify Document",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/api/student-documents/1/verify?status=VERIFIED",
              "query": [{ "key": "status", "value": "VERIFIED" }]
            }
          }
        }
      ]
    },
    {
      "name": "14 - Error Scenarios",
      "item": [
        {
          "name": "401 - No Token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/api/courses"
          }
        },
        {
          "name": "400 - Validation Error (empty body)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": { "mode": "raw", "raw": "{}" }
          }
        },
        {
          "name": "404 - Course Not Found",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/courses/99999" }
        },
        {
          "name": "400 - Invalid fileUri format",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/assessments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseId\": 1,\n  \"title\": \"Test\",\n  \"type\": \"EXAM\",\n  \"fileUri\": \"not-a-valid-uri\"\n}"
            }
          }
        }
      ]
    }
  ]
}
