{
  "info": {
    "name": "EduConnect - com.cognizant.educonnect (With IAM Audit Logs)",
    "description": "Complete API collection for EduConnect.\n\nTwo distinct audit concepts:\n1. IAM Audit Logs (/api/audit-logs) — tracks user identity & access events (login, registration, role changes)\n2. Compliance Audits (/api/compliance/audits) — formal governance audits of courses/programs\n\nHow to use:\n1. Run any Login in folder 01\n2. Token auto-saves to {{token}}\n3. All requests use it automatically\n\nPre-seeded credentials (password: password123):\n- admin@educonnect.com (ADMIN)\n- sarah.johnson@educonnect.com (TEACHER)\n- michael.chen@educonnect.com (TEACHER)\n- manager@educonnect.com (PROGRAM_MANAGER)\n- compliance@educonnect.com (COMPLIANCE_OFFICER)\n- auditor@educonnect.com (GOVERNMENT_AUDITOR)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "token",          "value": "", "type": "string" },
    { "key": "userId",         "value": "1","type": "string" },
    { "key": "studentId",      "value": "1","type": "string" },
    { "key": "teacherUserId",  "value": "2","type": "string" },
    { "key": "courseId",       "value": "1","type": "string" },
    { "key": "enrollmentId",   "value": "1","type": "string" },
    { "key": "contentId",      "value": "1","type": "string" },
    { "key": "assessmentId",   "value": "1","type": "string" },
    { "key": "submissionId",   "value": "1","type": "string" },
    { "key": "notificationId", "value": "1","type": "string" },
    { "key": "complianceId",   "value": "1","type": "string" },
    { "key": "auditId",        "value": "1","type": "string" },
    { "key": "auditLogId",     "value": "1","type": "string" },
    { "key": "docId",          "value": "1","type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "01 - Authentication (Public)",
      "description": "No token required. Login saves token automatically.",
      "item": [
        {
          "name": "Register - ADMIN",
          "request": { "auth": {"type":"noauth"}, "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": { "raw": "http://localhost:8081/api/auth/register", "protocol":"http","host":["localhost"],"port":"8081","path":["api","auth","register"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"System Admin\",\n  \"email\": \"sysadmin@test.com\",\n  \"password\": \"password123\",\n  \"role\": \"ADMIN\"\n}" }
          }
        },
        {
          "name": "Register - TEACHER",
          "request": { "auth": {"type":"noauth"}, "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": { "raw": "http://localhost:8081/api/auth/register", "protocol":"http","host":["localhost"],"port":"8081","path":["api","auth","register"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Dr. Jane Smith\",\n  \"email\": \"jane.smith@test.com\",\n  \"password\": \"password123\",\n  \"role\": \"TEACHER\"\n}" }
          }
        },
        {
          "name": "Register - STUDENT",
          "event": [{"listen":"test","script":{"exec":["var r=pm.response.json();if(r.data&&r.data.userId){pm.collectionVariables.set('userId',r.data.userId);console.log('userId saved:',r.data.userId);}"],"type":"text/javascript"}}],
          "request": { "auth": {"type":"noauth"}, "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": { "raw": "http://localhost:8081/api/auth/register", "protocol":"http","host":["localhost"],"port":"8081","path":["api","auth","register"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Alice Johnson\",\n  \"email\": \"alice@student.com\",\n  \"password\": \"password123\",\n  \"role\": \"STUDENT\",\n  \"phone\": \"9876543210\"\n}" }
          }
        },
        {
          "name": "Register - COMPLIANCE_OFFICER",
          "request": { "auth": {"type":"noauth"}, "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": { "raw": "http://localhost:8081/api/auth/register", "protocol":"http","host":["localhost"],"port":"8081","path":["api","auth","register"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Compliance Off\",\n  \"email\": \"co@test.com\",\n  \"password\": \"password123\",\n  \"role\": \"COMPLIANCE_OFFICER\"\n}" }
          }
        },
        {
          "name": "Login as ADMIN (saves token)",
          "event": [{"listen":"test","script":{"exec":["var r=pm.response.json();if(r.data&&r.data.accessToken){pm.collectionVariables.set('token',r.data.accessToken);console.log('✅ ADMIN token saved');}"],"type":"text/javascript"}}],
          "request": { "auth": {"type":"noauth"}, "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": { "raw": "http://localhost:8081/api/auth/login", "protocol":"http","host":["localhost"],"port":"8081","path":["api","auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@educonnect.com\",\n  \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Login as TEACHER (saves token)",
          "event": [{"listen":"test","script":{"exec":["var r=pm.response.json();if(r.data&&r.data.accessToken){pm.collectionVariables.set('token',r.data.accessToken);pm.collectionVariables.set('teacherUserId',r.data.userId);console.log('✅ TEACHER token saved');}"],"type":"text/javascript"}}],
          "request": { "auth": {"type":"noauth"}, "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": { "raw": "http://localhost:8081/api/auth/login", "protocol":"http","host":["localhost"],"port":"8081","path":["api","auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"sarah.johnson@educonnect.com\",\n  \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Login as STUDENT (saves token)",
          "event": [{"listen":"test","script":{"exec":["var r=pm.response.json();if(r.data&&r.data.accessToken){pm.collectionVariables.set('token',r.data.accessToken);console.log('✅ STUDENT token saved');}"],"type":"text/javascript"}}],
          "request": { "auth": {"type":"noauth"}, "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": { "raw": "http://localhost:8081/api/auth/login", "protocol":"http","host":["localhost"],"port":"8081","path":["api","auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"alice@student.com\",\n  \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Login as COMPLIANCE_OFFICER (saves token)",
          "event": [{"listen":"test","script":{"exec":["var r=pm.response.json();if(r.data&&r.data.accessToken){pm.collectionVariables.set('token',r.data.accessToken);console.log('✅ COMPLIANCE token saved');}"],"type":"text/javascript"}}],
          "request": { "auth": {"type":"noauth"}, "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": { "raw": "http://localhost:8081/api/auth/login", "protocol":"http","host":["localhost"],"port":"8081","path":["api","auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"compliance@educonnect.com\",\n  \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Login - Wrong Password [expect 401]",
          "request": { "auth": {"type":"noauth"}, "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": { "raw": "http://localhost:8081/api/auth/login", "protocol":"http","host":["localhost"],"port":"8081","path":["api","auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@educonnect.com\",\n  \"password\": \"wrongpassword\"\n}" }
          }
        },
        {
          "name": "Login - Validation Error [expect 400]",
          "request": { "auth": {"type":"noauth"}, "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": { "raw": "http://localhost:8081/api/auth/login", "protocol":"http","host":["localhost"],"port":"8081","path":["api","auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"not-valid\",\n  \"password\": \"\"\n}" }
          }
        }
      ]
    },
    {
      "name": "02 - IAM Audit Logs (ADMIN, COMPLIANCE_OFFICER, GOVERNMENT_AUDITOR)",
      "description": "Identity & Access Management Audit Trail.\n\nTracks: User logins, registrations, role changes, account status changes, password resets, access events.\n\nIMPORTANT: This is DIFFERENT from Compliance Audits:\n- IAM Audit Logs (/api/audit-logs) = WHO did WHAT in the system (identity events)\n- Compliance Audits (/api/compliance/audits) = Formal governance audits of courses/programs\n\nRequired roles: ADMIN, COMPLIANCE_OFFICER, GOVERNMENT_AUDITOR",
      "item": [
        {
          "name": "Get All IAM Audit Logs",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:8081/api/audit-logs", "protocol":"http","host":["localhost"],"port":"8081","path":["api","audit-logs"] }
          }
        },
        {
          "name": "Get IAM Audit Log by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:8081/api/audit-logs/{{auditLogId}}", "protocol":"http","host":["localhost"],"port":"8081","path":["api","audit-logs","{{auditLogId}}"] }
          }
        },
        {
          "name": "Get IAM Audit Logs by User",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:8081/api/audit-logs/user/{{userId}}", "protocol":"http","host":["localhost"],"port":"8081","path":["api","audit-logs","user","{{userId}}"] }
          }
        },
        {
          "name": "Get IAM Audit Logs by Date Range",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8081/api/audit-logs/date-range?from=2024-01-01T00:00:00&to=2024-12-31T23:59:59",
              "protocol":"http","host":["localhost"],"port":"8081","path":["api","audit-logs","date-range"],
              "query": [
                { "key": "from", "value": "2024-01-01T00:00:00" },
                { "key": "to",   "value": "2024-12-31T23:59:59" }
              ]
            }
          }
        },
        {
          "name": "Record IAM Audit Log - USER_LOGIN",
          "event": [{"listen":"test","script":{"exec":["var r=pm.response.json();if(r.data&&r.data.auditLogId){pm.collectionVariables.set('auditLogId',r.data.auditLogId);console.log('auditLogId saved:',r.data.auditLogId);}"],"type":"text/javascript"}}],
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": { "raw": "http://localhost:8081/api/audit-logs", "protocol":"http","host":["localhost"],"port":"8081","path":["api","audit-logs"] },
            "body": { "mode": "raw", "raw": "{\n  \"userId\": 1,\n  \"action\": \"USER_LOGIN\",\n  \"resource\": \"auth/login\"\n}" }
          }
        },
        {
          "name": "Record IAM Audit Log - USER_LOGOUT",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": { "raw": "http://localhost:8081/api/audit-logs", "protocol":"http","host":["localhost"],"port":"8081","path":["api","audit-logs"] },
            "body": { "mode": "raw", "raw": "{\n  \"userId\": 1,\n  \"action\": \"USER_LOGOUT\",\n  \"resource\": \"auth/logout\"\n}" }
          }
        },
        {
          "name": "Record IAM Audit Log - USER_REGISTERED",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": { "raw": "http://localhost:8081/api/audit-logs", "protocol":"http","host":["localhost"],"port":"8081","path":["api","audit-logs"] },
            "body": { "mode": "raw", "raw": "{\n  \"userId\": 1,\n  \"action\": \"USER_REGISTERED\",\n  \"resource\": \"users/1\"\n}" }
          }
        },
        {
          "name": "Record IAM Audit Log - ROLE_CHANGED",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": { "raw": "http://localhost:8081/api/audit-logs", "protocol":"http","host":["localhost"],"port":"8081","path":["api","audit-logs"] },
            "body": { "mode": "raw", "raw": "{\n  \"userId\": 1,\n  \"action\": \"ROLE_CHANGED\",\n  \"resource\": \"users/3/role/COMPLIANCE_OFFICER\"\n}" }
          }
        },
        {
          "name": "Record IAM Audit Log - ACCOUNT_SUSPENDED",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": { "raw": "http://localhost:8081/api/audit-logs", "protocol":"http","host":["localhost"],"port":"8081","path":["api","audit-logs"] },
            "body": { "mode": "raw", "raw": "{\n  \"userId\": 1,\n  \"action\": \"ACCOUNT_SUSPENDED\",\n  \"resource\": \"users/5/status\"\n}" }
          }
        },
        {
          "name": "Record IAM Audit Log - PASSWORD_CHANGED",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": { "raw": "http://localhost:8081/api/audit-logs", "protocol":"http","host":["localhost"],"port":"8081","path":["api","audit-logs"] },
            "body": { "mode": "raw", "raw": "{\n  \"userId\": 1,\n  \"action\": \"PASSWORD_CHANGED\",\n  \"resource\": \"users/1/password\"\n}" }
          }
        },
        {
          "name": "Record IAM Audit Log - PERMISSION_DENIED",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": { "raw": "http://localhost:8081/api/audit-logs", "protocol":"http","host":["localhost"],"port":"8081","path":["api","audit-logs"] },
            "body": { "mode": "raw", "raw": "{\n  \"userId\": 2,\n  \"action\": \"PERMISSION_DENIED\",\n  \"resource\": \"api/users\"\n}" }
          }
        },
        {
          "name": "Record IAM Audit Log - ACCOUNT_ACTIVATED",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": { "raw": "http://localhost:8081/api/audit-logs", "protocol":"http","host":["localhost"],"port":"8081","path":["api","audit-logs"] },
            "body": { "mode": "raw", "raw": "{\n  \"userId\": 1,\n  \"action\": \"ACCOUNT_ACTIVATED\",\n  \"resource\": \"users/5/status\"\n}" }
          }
        },
        {
          "name": "Record IAM Audit Log - Validation Error [expect 400]",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": { "raw": "http://localhost:8081/api/audit-logs", "protocol":"http","host":["localhost"],"port":"8081","path":["api","audit-logs"] },
            "body": { "mode": "raw", "raw": "{\n  \"userId\": null,\n  \"action\": \"\"\n}" }
          }
        },
        {
          "name": "Get Audit Log - Not Found [expect 404]",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:8081/api/audit-logs/99999", "protocol":"http","host":["localhost"],"port":"8081","path":["api","audit-logs","99999"] }
          }
        }
      ]
    },
    {
      "name": "03 - Users (ADMIN only)",
      "item": [
        { "name": "Get All Users", "request": { "method": "GET", "url": { "raw": "http://localhost:8081/api/users", "protocol":"http","host":["localhost"],"port":"8081","path":["api","users"] } } },
        { "name": "Get User by ID", "request": { "method": "GET", "url": { "raw": "http://localhost:8081/api/users/{{userId}}", "protocol":"http","host":["localhost"],"port":"8081","path":["api","users","{{userId}}"] } } },
        { "name": "Get Users by Role - TEACHER", "request": { "method": "GET", "url": { "raw": "http://localhost:8081/api/users/role/TEACHER", "protocol":"http","host":["localhost"],"port":"8081","path":["api","users","role","TEACHER"] } } },
        { "name": "Get Users by Role - STUDENT", "request": { "method": "GET", "url": { "raw": "http://localhost:8081/api/users/role/STUDENT", "protocol":"http","host":["localhost"],"port":"8081","path":["api","users","role","STUDENT"] } } },
        { "name": "Get Users by Role - ADMIN", "request": { "method": "GET", "url": { "raw": "http://localhost:8081/api/users/role/ADMIN", "protocol":"http","host":["localhost"],"port":"8081","path":["api","users","role","ADMIN"] } } },
        { "name": "Update User Status - SUSPEND", "request": { "method": "PATCH", "url": { "raw": "http://localhost:8081/api/users/{{userId}}/status?status=SUSPENDED", "protocol":"http","host":["localhost"],"port":"8081","path":["api","users","{{userId}}","status"],"query":[{"key":"status","value":"SUSPENDED"}] } } },
        { "name": "Update User Status - ACTIVATE", "request": { "method": "PATCH", "url": { "raw": "http://localhost:8081/api/users/{{userId}}/status?status=ACTIVE", "protocol":"http","host":["localhost"],"port":"8081","path":["api","users","{{userId}}","status"],"query":[{"key":"status","value":"ACTIVE"}] } } },
        { "name": "Delete (Deactivate) User", "request": { "method": "DELETE", "url": { "raw": "http://localhost:8081/api/users/{{userId}}", "protocol":"http","host":["localhost"],"port":"8081","path":["api","users","{{userId}}"] } } }
      ]
    },
    {
      "name": "04 - Students",
      "item": [
        { "name": "Get All Students", "request": { "method": "GET", "url": { "raw": "http://localhost:8081/api/students", "protocol":"http","host":["localhost"],"port":"8081","path":["api","students"] } } },
        { "name": "Get Student by ID", "event": [{"listen":"test","script":{"exec":["var r=pm.response.json();if(r.data&&r.data.studentId){pm.collectionVariables.set('studentId',r.data.studentId);}"],"type":"text/javascript"}}], "request": { "method": "GET", "url": { "raw": "http://localhost:8081/api/students/{{studentId}}", "protocol":"http","host":["localhost"],"port":"8081","path":["api","students","{{studentId}}"] } } },
        { "name": "Get Student by User ID", "event": [{"listen":"test","script":{"exec":["var r=pm.response.json();if(r.data&&r.data.studentId){pm.collectionVariables.set('studentId',r.data.studentId);console.log('studentId saved:',r.data.studentId);}"],"type":"text/javascript"}}], "request": { "method": "GET", "url": { "raw": "http://localhost:8081/api/students/user/{{userId}}", "protocol":"http","host":["localhost"],"port":"8081","path":["api","students","user","{{userId}}"] } } }
      ]
    },
    {
      "name": "05 - Student Documents",
      "item": [
        { "name": "Get Documents by Student", "request": { "method": "GET", "url": { "raw": "http://localhost:8081/api/student-documents/student/{{studentId}}", "protocol":"http","host":["localhost"],"port":"8081","path":["api","student-documents","student","{{studentId}}"] } } },
        { "name": "Upload ID Proof", "event": [{"listen":"test","script":{"exec":["var r=pm.response.json();if(r.data&&r.data.documentId){pm.collectionVariables.set('docId',r.data.documentId);}"],"type":"text/javascript"}}], "request": { "method": "POST", "url": { "raw": "http://localhost:8081/api/student-documents/student/{{studentId}}?docType=ID_PROOF&fileUri=https://s3.amazonaws.com/docs/id.jpg", "protocol":"http","host":["localhost"],"port":"8081","path":["api","student-documents","student","{{studentId}}"],"query":[{"key":"docType","value":"ID_PROOF"},{"key":"fileUri","value":"https://s3.amazonaws.com/docs/id.jpg"}] } } },
        { "name": "Verify Document - VERIFIED", "request": { "method": "PATCH", "url": { "raw": "http://localhost:8081/api/student-documents/{{docId}}/verify?status=VERIFIED", "protocol":"http","host":["localhost"],"port":"8081","path":["api","student-documents","{{docId}}","verify"],"query":[{"key":"status","value":"VERIFIED"}] } } }
      ]
    },
    {
      "name": "06 - Courses",
      "item": [
        { "name": "Get All Courses", "request": { "method": "GET", "url": { "raw": "http://localhost:8081/api/courses", "protocol":"http","host":["localhost"],"port":"8081","path":["api","courses"] } } },
        { "name": "Get Course by ID", "request": { "method": "GET", "url": { "raw": "http://localhost:8081/api/courses/{{courseId}}", "protocol":"http","host":["localhost"],"port":"8081","path":["api","courses","{{courseId}}"] } } },
        { "name": "Search Courses", "request": { "method": "GET", "url": { "raw": "http://localhost:8081/api/courses/search?keyword=Java", "protocol":"http","host":["localhost"],"port":"8081","path":["api","courses","search"],"query":[{"key":"keyword","value":"Java"}] } } },
        { "name": "Get Courses by Teacher", "request": { "method": "GET", "url": { "raw": "http://localhost:8081/api/courses/teacher/{{teacherUserId}}", "protocol":"http","host":["localhost"],"port":"8081","path":["api","courses","teacher","{{teacherUserId}}"] } } },
        { "name": "Create Course", "event": [{"listen":"test","script":{"exec":["var r=pm.response.json();if(r.data&&r.data.courseId){pm.collectionVariables.set('courseId',r.data.courseId);console.log('courseId saved:',r.data.courseId);}"],"type":"text/javascript"}}], "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "url": { "raw": "http://localhost:8081/api/courses", "protocol":"http","host":["localhost"],"port":"8081","path":["api","courses"] }, "body": { "mode": "raw", "raw": "{\n  \"title\": \"Advanced Algorithms\",\n  \"description\": \"Deep dive into sorting, searching and graph algorithms.\",\n  \"teacherId\": 2,\n  \"startDate\": \"2024-05-01\",\n  \"endDate\": \"2024-10-31\"\n}" } } },
        { "name": "Update Course", "request": { "method": "PUT", "header": [{"key":"Content-Type","value":"application/json"}], "url": { "raw": "http://localhost:8081/api/courses/{{courseId}}", "protocol":"http","host":["localhost"],"port":"8081","path":["api","courses","{{courseId}}"] }, "body": { "mode": "raw", "raw": "{\n  \"title\": \"Advanced Algorithms - Updated\",\n  \"description\": \"Updated description.\",\n  \"teacherId\": 2,\n  \"startDate\": \"2024-05-01\",\n  \"endDate\": \"2024-11-30\"\n}" } } },
        { "name": "Archive Course", "request": { "method": "DELETE", "url": { "raw": "http://localhost:8081/api/courses/{{courseId}}", "protocol":"http","host":["localhost"],"port":"8081","path":["api","courses","{{courseId}}"] } } }
      ]
    },
    {
      "name": "07 - Curriculum",
      "item": [
        { "name": "Get Curriculum by Course", "request": { "method": "GET", "url": { "raw": "http://localhost:8081/api/curriculum/course/{{courseId}}", "protocol":"http","host":["localhost"],"port":"8081","path":["api","curriculum","course","{{courseId}}"] } } },
        { "name": "Create/Update Curriculum", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "url": { "raw": "http://localhost:8081/api/curriculum/course/{{courseId}}", "protocol":"http","host":["localhost"],"port":"8081","path":["api","curriculum","course","{{courseId}}"] }, "body": { "mode": "raw", "raw": "{\"weeks\":[{\"week\":1,\"topic\":\"Introduction\"},{\"week\":2,\"topic\":\"Core Concepts\"},{\"week\":3,\"topic\":\"Advanced Topics\"}]}" } } }
      ]
    },
    {
